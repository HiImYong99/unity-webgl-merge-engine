# ── 서명 설정 템플릿 ──────────────────────────────────────────────
# 이 파일을 복사하여 signing.properties 로 저장 후 아래 값을 채우세요.
# signing.properties는 .gitignore에 포함되어 있어 저장소에 업로드되지 않습니다.
#
# 사용법:
#   cp signing.properties.template signing.properties
#   # 아래 값을 실제 keystore 정보로 수정

storeFile=../../user.keystore
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=animalpop
keyPassword=YOUR_KEY_PASSWORD
