# This .gitignore file is optimized for Unity projects.
# -------------------------------------------------------------------------

# [Unity]
# -------------------------------------------------------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
ait-build/
[Aa]ssets/AssetStoreTools*

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# [OS Specific]
# -------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon


# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# [IDEs]
# -------------------------------------------------------------------------
.vs/
.idea/
.vscode/

# [WebGL/Packages]
# -------------------------------------------------------------------------
/Build/
/Recordings/
/[Yy]arnData/
node_modules/
package-lock.json

# [Builds]
# -------------------------------------------------------------------------
/[Bb]uilds/
/[Pp]ublish/

# [Backup]
# -------------------------------------------------------------------------
*.bak
*.tmp
*.old

# [User Settings]
# -------------------------------------------------------------------------
UserSettings/
!ProjectSettings/
ProjectSettings/ProjectVersion.txt

# Apps in Toss SDK - 자동 보호 패턴
**/AITCredentials.asset
**/AITCredentials.asset.meta

# [Android Builds]
# -------------------------------------------------------------------------
*.aab
*.apk

# [Logs]
# -------------------------------------------------------------------------
*.log
unity-build.log

# [Sensitive / Security]
# -------------------------------------------------------------------------
*.keystore
*.jks
signing.properties
local.properties

# [Android Gradle Cache]
# -------------------------------------------------------------------------
android-wrapper/.gradle/

# [Claude / AI Tools]
# -------------------------------------------------------------------------
.claudesignore
prompt.md
